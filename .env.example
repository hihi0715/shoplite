# ShopLite environment variables — copy to .env and fill in values

# Application
ENVIRONMENT=development
APP_NAME=ShopLite

# Optional API key for protected endpoints (leave empty to disable auth in dev)
API_SECRET_KEY=your-secret-key-here

# MapReduce: set false on Vercel serverless (default), true for local multiprocessing
USE_MULTIPROCESSING=false

# K-Means defaults
KMEANS_CLUSTERS=3
KMEANS_MAX_ITER=10
MAPREDUCE_WORKERS=4
